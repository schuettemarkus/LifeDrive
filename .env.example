# --- Supabase ---
# Public — exposed to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secret — server only. Required for the seed script and any server-side admin work.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (server-only) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_REASON=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-7

# --- Google OAuth (server-only) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/calendar/oauth/callback

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used as the Google Calendar event extended property key to tag events we created.
LIFE_DRIVE_EVENT_TAG=lifeDrive

# --- Sentry (optional; errors go silent if unset) ---
# Same DSN can be used for client (PUBLIC_) and server. Server-only build vars
# enable source-map upload at build time.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Web Push (optional; subscription routes 503 if VAPID keys missing) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_CONTACT_EMAIL=mailto:you@example.com
# Bearer token a cron caller must present to /api/push/cron/morning
PUSH_CRON_SECRET=
